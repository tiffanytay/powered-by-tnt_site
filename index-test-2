<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tiffany Tay - Operations & Analytics Portfolio</title>
    <script src="https://cdn.tailwindcss.com/3.4.16"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#E50914', // Netflix Red
                        netflixBlack: '#141414',
                        netflixGray: '#181818'
                    }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/remixicon/4.6.0/remixicon.min.css">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #141414;
            color: white;
            overflow-x: hidden;
        }

        /* Netflix Row Hover Effect */
        .project-row {
            display: flex;
            gap: 10px;
            overflow-x: auto;
            padding: 40px 0;
            scrollbar-width: none; /* Firefox */
        }
        .project-row::-webkit-scrollbar { display: none; }

        .project-card {
            min-width: 300px;
            transition: transform 0.4s ease, z-index 0.4s ease;
            position: relative;
        }

        .project-card:hover {
            transform: scale(1.25);
            z-index: 50;
            cursor: pointer;
        }

        .hero-vignette {
            background: linear-gradient(77deg, rgba(0,0,0,.8) 0, rgba(0,0,0,0) 85%),
                        linear-gradient(0deg, rgba(20,20,20,1) 0, rgba(20,20,20,0) 25%);
        }

        .nav-gradient {
            background: linear-gradient(to bottom, rgba(0,0,0,0.7) 10%, transparent);
        }
    </style>
</head>
<body>

<header class="fixed w-full z-[100] nav-gradient transition-all duration-500" id="navbar">
    <div class="container mx-auto px-10 flex justify-between h-20 items-center">
        <div class="flex items-center gap-10">
            <a href="#" class="text-primary font-bold text-3xl tracking-tighter">TIFFANY TAY</a>
            <nav class="hidden lg:flex space-x-5 text-sm font-light text-gray-300">
                <a href="#home" class="hover:text-white transition">Home</a>
                <a href="#projects" class="hover:text-white transition">Series</a>
                <a href="#skills" class="hover:text-white transition">New & Popular</a>
                <a href="#about" class="hover:text-white transition">My List</a>
            </nav>
        </div>
        <div class="flex items-center space-x-5 text-white">
            <i class="ri-search-line text-xl cursor-pointer"></i>
            <div class="w-8 h-8 bg-blue-600 rounded"></div>
        </div>
    </div>
</header>

<section id="home" class="relative h-[85vh] w-full flex items-center">
    <div class="absolute inset-0 z-0">
        <img src="https://images.unsplash.com/photo-1551288049-bbbda546697c?auto=format&fit=crop&q=80&w=2000" 
             class="w-full h-full object-cover" alt="Hero Background">
        <div class="absolute inset-0 hero-vignette"></div>
    </div>

    <div class="container mx-auto px-10 z-10">
        <h2 class="text-gray-400 font-bold mb-2 tracking-widest text-sm">ORIGINAL STRATEGY</h2>
        <h1 class="text-5xl md:text-7xl font-extrabold text-white mb-4 max-w-2xl leading-tight">
            Operations & Analytics Leadership
        </h1>
        <p class="text-lg text-white max-w-xl mb-6 drop-shadow-lg">
            Bridging technology and social impact through innovative process optimization. 
            Now streaming "Scalable Nonprofit Solutions."
        </p>
        <div class="flex gap-3">
            <button class="bg-white text-black px-8 py-2 rounded font-bold flex items-center gap-2 hover:bg-opacity-80 transition">
                <i class="ri-play-fill text-2xl"></i> View Work
            </button>
            <button class="bg-gray-500 bg-opacity-50 text-white px-8 py-2 rounded font-bold flex items-center gap-2 hover:bg-opacity-40 transition">
                <i class="ri-information-line text-2xl"></i> More Info
            </button>
        </div>
    </div>
</section>

<section id="projects" class="relative z-20 -mt-20 px-10 pb-10">
    <h3 class="text-xl font-semibold text-gray-200 mb-2">Blockbuster Dashboards</h3>
    <div class="project-row">
        <div class="project-card bg-netflixGray rounded-md overflow-hidden shadow-2xl">
            <img src="graphics/coqual-990-financial-screenshot.png" class="w-full h-40 object-cover" alt="Project">
            <div class="p-4 bg-netflixGray">
                <div class="flex gap-2 mb-2">
                    <i class="ri-play-circle-fill text-white text-2xl"></i>
                    <i class="ri-add-line text-white text-2xl border-2 border-gray-500 rounded-full px-1"></i>
                </div>
                <p class="text-green-500 font-bold text-xs">98% Match <span class="text-gray-400 ml-2 font-normal">2024</span></p>
                <p class="text-white text-sm mt-1">Nonprofit Insights Dashboard</p>
            </div>
        </div>

        <div class="project-card bg-netflixGray rounded-md overflow-hidden">
            <img src="graphics/projmgmt-dashboard.png" class="w-full h-40 object-cover" alt="Project">
            <div class="p-4 bg-netflixGray">
                <div class="flex gap-2 mb-2">
                    <i class="ri-play-circle-fill text-white text-2xl"></i>
                    <i class="ri-add-line text-white text-2xl border-2 border-gray-500 rounded-full px-1"></i>
                </div>
                <p class="text-green-500 font-bold text-xs">95% Match <span class="text-gray-400 ml-2 font-normal">2023</span></p>
                <p class="text-white text-sm mt-1">PM Optimization Tool</p>
            </div>
        </div>

        <div class="project-card bg-netflixGray rounded-md overflow-hidden">
            <img src="graphics/nkc-screenshot_tiffany-tay.png" class="w-full h-40 object-cover" alt="Project">
            <div class="p-4 bg-netflixGray">
                <div class="flex gap-2 mb-2">
                    <i class="ri-play-circle-fill text-white text-2xl"></i>
                    <i class="ri-add-line text-white text-2xl border-2 border-gray-500 rounded-full px-1"></i>
                </div>
                <p class="text-green-500 font-bold text-xs">99% Match <span class="text-gray-400 ml-2 font-normal">2024</span></p>
                <p class="text-white text-sm mt-1">Data for Paws</p>
            </div>
        </div>
        
        </div>
</section>

<section id="skills" class="py-10 px-10">
    <h3 class="text-xl font-semibold text-gray-200 mb-6">Trending Skills</h3>
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4">
        <div class="bg-netflixGray p-6 rounded hover:bg-white hover:text-black transition cursor-pointer group">
            <i class="ri-bar-chart-fill text-primary group-hover:text-black text-3xl mb-3"></i>
            <h4 class="font-bold">Power BI</h4>
            <p class="text-xs text-gray-400 group-hover:text-black">7+ Years Experience</p>
        </div>
        <div class="bg-netflixGray p-6 rounded hover:bg-white hover:text-black transition cursor-pointer group">
            <i class="ri-code-s-slash-line text-primary group-hover:text-black text-3xl mb-3"></i>
            <h4 class="font-bold">Python</h4>
            <p class="text-xs text-gray-400 group-hover:text-black">Intermediate</p>
        </div>
        </div>
</section>

<script>
    // Navbar scroll effect
    window.addEventListener('scroll', () => {
        const nav = document.getElementById('navbar');
        if (window.scrollY > 50) {
            nav.style.backgroundColor = '#141414';
        } else {
            nav.style.backgroundColor = 'transparent';
        }
    });
</script>

</body>
</html>
